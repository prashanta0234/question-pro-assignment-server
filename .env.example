NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=grocery_user
DB_PASSWORD=grocery_pass
DB_NAME=grocery_booking

# Redis (single instance — db0=cache/idempotency, db1=BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — use at least 64 random characters in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_64_character_minimum_random_secret_before_deploying_to_production
JWT_EXPIRES_IN=15m

# Business rules
LOW_STOCK_THRESHOLD=10

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Admin seed — credentials used by the seed script to create the first ADMIN user
# Run: pnpm seed:admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@SecurePass123
